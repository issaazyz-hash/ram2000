# Frontend Environment Variables (Vite)
# Copy this file to .env for development or .env.production for production builds
# DO NOT commit .env files to version control

# API Base URL (must include /api suffix)
# Development: Use localhost with backend port
VITE_API_BASE_URL=http://localhost:3000/api

# Production: Use relative path if frontend and backend are on same domain
# OR use full URL if backend is on different domain/IP
# VITE_API_BASE_URL=/api
# OR
# VITE_API_BASE_URL=http://your-backend-ip:3000/api
