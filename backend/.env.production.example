# Frontend Production Environment Variables (Vite)
# Copy this file to .env.production for production builds

# API Base URL for production
# Option 1: Relative path (if frontend and backend are on same domain via reverse proxy)
VITE_API_BASE_URL=/api

# Option 2: Full URL (if backend is on different domain/IP)
# VITE_API_BASE_URL=http://69.169.108.182:3000/api

# Option 3: If using environment variable at build time, leave empty and set it during build:
# VITE_API_BASE_URL=
